VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GEMINI_API_KEY is now stored server-side as a Supabase secret.
# Set it via: supabase secrets set GEMINI_API_KEY=your-key-here
# The frontend calls the gemini-proxy Edge Function instead of Gemini directly.
